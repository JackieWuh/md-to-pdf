{
  "name": "md-to-pdf",
  "version": "1.0.0",
  "description": "CLI tool to convert Markdown API docs to PDF",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "md-to-pdf": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest --run",
    "test:watch": "vitest",
    "web": "node dist/server.js"
  },
  "keywords": [
    "markdown",
    "pdf",
    "api-docs",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "puppeteer-core": "^24.38.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.4.0",
    "fast-check": "^4.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
